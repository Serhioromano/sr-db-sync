{
  "name": "sr-db-sync",
  "version": "1.0.13",
  "description": "CLI utility for bidirectional conversion between database and DBML (Database Markup Language)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "dbs": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --minify",
    "prepublishOnly": "bun run build",
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "typecheck": "bun run build --noEmit",
    "snash": "bun ./src/index.ts  snash --dsn migration/test.db --engine sqlite --file migration/test.dbml"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Serhioromano/sr-db-sync.git"
  },
  "keywords": [
    "db",
    "migration",
    "sync",
    "database",
    "schema",
    "versioning",
    "dbml",
    "sqlite",
    "mysql"
  ],
  "author": "Sergey Romanov",
  "license": "MIT",
  "type": "module",
  "bugs": {
    "url": "https://github.com/Serhioromano/sr-db-sync/issues"
  },
  "homepage": "https://github.com/Serhioromano/sr-db-sync#readme",
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.9.3",
    "fallow": "^2.97.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "mysql2": "^3.22.5"
  }
}
